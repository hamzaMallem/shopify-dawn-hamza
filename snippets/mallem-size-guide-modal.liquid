{%- comment -%}
  Component: Size Guide Modal
  Purpose: Global modal container for size guide content
  Used in: Rendered once in layout/theme.liquid

  Features:
  - Single modal instance (reused for all products)
  - Content injected dynamically via JavaScript
  - Close button with large tap target
  - Backdrop click to close
  - Keyboard accessible (Escape to close)
  - Focus trap when open
  - Body scroll lock

  RTL: CSS logical properties throughout
  Performance: Hidden by default, minimal DOM footprint
{%- endcomment -%}

<div
  id="mallem-size-guide-modal"
  class="mallem-size-guide-modal"
  role="dialog"
  aria-modal="true"
  aria-labelledby="size-guide-modal-title"
  aria-hidden="true"
  hidden
>
  {%- comment -%} Backdrop {%- endcomment -%}
  <div class="mallem-size-guide-modal__backdrop" data-modal-backdrop></div>

  {%- comment -%} Dialog {%- endcomment -%}
  <div class="mallem-size-guide-modal__dialog" role="document">
    {%- comment -%} Header {%- endcomment -%}
    <div class="mallem-size-guide-modal__header">
      <h2 id="size-guide-modal-title" class="mallem-size-guide-modal__title">
        {%- comment -%} Title injected by JS {%- endcomment -%}
      </h2>

      <button
        type="button"
        class="mallem-size-guide-modal__close"
        data-modal-close
        aria-label="{{ 'accessibility.close' | t }}"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M15 5L5 15M5 5L15 15" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    {%- comment -%} Body {%- endcomment -%}
    <div class="mallem-size-guide-modal__body">
      {%- comment -%} Image container (optional, shown if image exists) {%- endcomment -%}
      <div class="mallem-size-guide-modal__image-wrapper" data-modal-image-container hidden>
        <img
          class="mallem-size-guide-modal__image"
          data-modal-image
          src=""
          alt=""
          width=""
          height=""
          loading="lazy"
        >
      </div>

      {%- comment -%} Content container {%- endcomment -%}
      <div class="mallem-size-guide-modal__content rte" data-modal-content>
        {%- comment -%} Content injected by JS {%- endcomment -%}
      </div>
    </div>
  </div>
</div>

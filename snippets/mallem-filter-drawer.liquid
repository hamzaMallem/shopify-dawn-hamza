{%- comment -%}
  Component: Filter Drawer
  Purpose: Mobile filter and sort slide-up/side panel (hidden on desktop)
  Used in: sections/mallem-collection.liquid

  Parameters:
    filters        {Array}   collection.filters
    enable_sorting {Boolean} show sort radio buttons
    sort_options   {Array}   collection.sort_options
    sort_by        {String}  active sort value

  Features:
  - Slides from bottom on mobile (< 750px), from inline-start on tablet
  - Focus trap while open (managed by mallem-filters.js)
  - Closes on overlay click, close button, or Escape key
  - Separate <form> from sidebar so both can coexist in DOM
  - Sort radios sync with desktop <select> via JS
  - Footer: "Clear all" link + "Apply" button

  RTL: `inset-inline-start` for panel placement; zero left/right values
  Performance: `hidden` attribute collapses element from layout until opened;
               CSS transition runs only after hidden is removed via requestAnimationFrame
{%- endcomment -%}

<div
  id="mallem-filter-drawer"
  class="mallem-filter-drawer"
  data-mallem-filter-drawer
  role="dialog"
  aria-modal="true"
  aria-label="{{ 'mallem.collection.filter_drawer_label' | t }}"
  hidden
>

  <div
    class="mallem-filter-drawer__overlay"
    data-mallem-drawer-overlay
    aria-hidden="true"
  ></div>

  <div class="mallem-filter-drawer__panel" data-mallem-drawer-panel>

    <div class="mallem-filter-drawer__header">
      <span class="mallem-filter-drawer__title">{{ 'mallem.collection.filter_sort' | t }}</span>
      <button
        type="button"
        class="mallem-filter-drawer__close"
        data-mallem-drawer-close
        aria-label="{{ 'mallem.collection.close_drawer' | t }}"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" focusable="false">
          <path d="M1 1l16 16M17 1L1 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

    <div class="mallem-filter-drawer__body">

      {%- if enable_sorting -%}
        <div class="mallem-filter-drawer__sort">
          <p class="mallem-filter-drawer__section-label" id="drawer-sort-label">
            {{ 'mallem.collection.sort_by_label' | t }}
          </p>
          <div class="mallem-filter-drawer__sort-options" role="radiogroup" aria-labelledby="drawer-sort-label">
            {%- for option in sort_options -%}
              <label class="mallem-filter-drawer__sort-option">
                <input
                  type="radio"
                  name="sort_by"
                  value="{{ option.value }}"
                  data-mallem-drawer-sort
                  {% if option.value == sort_by %}checked{% endif %}
                >
                <span>{{ option.name }}</span>
              </label>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

      <form
        id="mallem-filter-form-drawer"
        class="mallem-filter-drawer__filters"
        data-mallem-filter-form
      >

        {%- for filter in filters -%}
          <details class="mallem-filter-group" data-mallem-filter-group open>

            <summary class="mallem-filter-group__header">
              <span class="mallem-filter-group__label">{{ filter.label | escape }}</span>
              {%- if filter.active_values.size > 0 -%}
                <span class="mallem-filter-group__count">{{ filter.active_values.size }}</span>
              {%- endif -%}
              <span class="mallem-filter-group__chevron" aria-hidden="true"></span>
            </summary>

            <div class="mallem-filter-group__body">

              {%- case filter.type -%}

                {%- when 'list' -%}
                  <ul class="mallem-filter-list" role="list">
                    {%- for value in filter.values -%}
                      <li class="mallem-filter-list__item">
                        <label
                          class="mallem-filter-checkbox"
                          for="DrawerFilter-{{ filter.param_name | escape }}-{{ forloop.index }}"
                        >
                          <input
                            type="checkbox"
                            class="mallem-filter-checkbox__input"
                            id="DrawerFilter-{{ filter.param_name | escape }}-{{ forloop.index }}"
                            name="{{ filter.param_name | escape }}"
                            value="{{ value.value | escape }}"
                            data-mallem-filter-input
                            {% if value.active %}checked{% endif %}
                            {% if value.count == 0 and value.active == false %}disabled{% endif %}
                          >
                          <span class="mallem-filter-checkbox__box" aria-hidden="true"></span>
                          <span class="mallem-filter-checkbox__label">
                            {{ value.label | escape }}
                            <span class="mallem-filter-checkbox__count">({{ value.count }})</span>
                          </span>
                        </label>
                      </li>
                    {%- endfor -%}
                  </ul>

                {%- when 'price_range' -%}
                  <div class="mallem-filter-price" data-mallem-price-filter>
                    <div class="mallem-filter-price__inputs">

                      <div class="mallem-filter-price__field">
                        <label
                          for="DrawerFilter-{{ filter.param_name | escape }}-GTE"
                          class="mallem-filter-price__label"
                        >{{ 'mallem.collection.price_from' | t }}</label>
                        <div class="mallem-filter-price__input-wrapper">
                          <span class="mallem-filter-price__currency" aria-hidden="true">
                            {{- cart.currency.symbol -}}
                          </span>
                          <input
                            type="number"
                            id="DrawerFilter-{{ filter.param_name | escape }}-GTE"
                            name="{{ filter.min_value.param_name }}"
                            class="mallem-filter-price__input"
                            data-mallem-price-min
                            data-mallem-filter-input
                            {%- if filter.min_value.value -%}
                              value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                            {%- endif -%}
                            placeholder="{{ filter.range_min | money_without_currency | replace: ',', '' }}"
                            min="{{ filter.range_min | money_without_currency | replace: ',', '' }}"
                            max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          >
                        </div>
                      </div>

                      <span class="mallem-filter-price__separator" aria-hidden="true">—</span>

                      <div class="mallem-filter-price__field">
                        <label
                          for="DrawerFilter-{{ filter.param_name | escape }}-LTE"
                          class="mallem-filter-price__label"
                        >{{ 'mallem.collection.price_to' | t }}</label>
                        <div class="mallem-filter-price__input-wrapper">
                          <span class="mallem-filter-price__currency" aria-hidden="true">
                            {{- cart.currency.symbol -}}
                          </span>
                          <input
                            type="number"
                            id="DrawerFilter-{{ filter.param_name | escape }}-LTE"
                            name="{{ filter.max_value.param_name }}"
                            class="mallem-filter-price__input"
                            data-mallem-price-max
                            data-mallem-filter-input
                            {%- if filter.max_value.value -%}
                              value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                            {%- endif -%}
                            placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                            min="{{ filter.range_min | money_without_currency | replace: ',', '' }}"
                            max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                          >
                        </div>
                      </div>

                    </div>
                  </div>

                {%- when 'boolean' -%}
                  <label
                    class="mallem-filter-checkbox"
                    for="DrawerFilter-{{ filter.param_name | escape }}"
                  >
                    <input
                      type="checkbox"
                      class="mallem-filter-checkbox__input"
                      id="DrawerFilter-{{ filter.param_name | escape }}"
                      name="{{ filter.param_name | escape }}"
                      value="1"
                      data-mallem-filter-input
                      {% if filter.active_values.size > 0 %}checked{% endif %}
                    >
                    <span class="mallem-filter-checkbox__box" aria-hidden="true"></span>
                    <span class="mallem-filter-checkbox__label">{{ filter.label | escape }}</span>
                  </label>

              {%- endcase -%}

            </div>
          </details>
        {%- endfor -%}

      </form>

    </div>{%- comment -%} /.mallem-filter-drawer__body {%- endcomment -%}

    <div class="mallem-filter-drawer__footer">
      <a
        href="{{ collection.url }}"
        class="mallem-filter-drawer__clear"
        data-mallem-clear-filters
      >{{ 'mallem.collection.clear_all' | t }}</a>
      <button
        type="button"
        class="mallem-filter-drawer__apply"
        data-mallem-drawer-close
      >{{ 'mallem.collection.apply_filters' | t }}</button>
    </div>

  </div>{%- comment -%} /.mallem-filter-drawer__panel {%- endcomment -%}

</div>

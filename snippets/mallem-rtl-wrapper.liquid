{%- comment -%}
  Component: mallem-rtl-wrapper
  Purpose: Controls RTL/LTR direction for entire theme
  Used in: layout/theme.liquid (<html> tag)

  Features:
  - Merchant-controlled RTL toggle via theme settings
  - Sets dir="rtl" or dir="ltr" on <html>
  - Sets lang="ar" when RTL enabled (Arabic default for MENA markets)
  - Outputs direction for use in body class

  RTL: Core RTL control mechanism
  Performance: Zero JavaScript, pure Liquid logic
{%- endcomment -%}

{%- liquid
  comment
    Check theme setting for RTL enablement
    WHY checkbox: Simple merchant control, no complex logic
  endcomment
  assign rtl_enabled = settings.mallem_enable_rtl

  comment
    Set HTML attributes based on RTL setting
    WHY lang="ar": Default to Arabic for MENA markets when RTL enabled
    WHY keep Shopify locale when disabled: Preserve multi-language support
  endcomment
  if rtl_enabled
    assign direction = 'rtl'
    assign html_lang = 'ar'
    assign direction_class = 'mallem-rtl'
  else
    assign direction = 'ltr'
    assign html_lang = request.locale.iso_code
    assign direction_class = 'mallem-ltr'
  endif
-%}

{%- comment -%}
  OUTPUT: HTML attributes for <html> tag
  Note: direction_class is captured for body class via assign
  Only output dir and lang here to avoid duplicate class attributes
{%- endcomment -%}
dir="{{ direction }}" lang="{{ html_lang }}" data-direction="{{ direction_class }}"

{%- comment -%}
  Component: Mallem Product Gallery
  Purpose: Zoomable, touch/keyboard-navigable product image gallery with
           vertical thumbnail rail and mobile dot indicators.
  Used in: sections/mallem-product-main.liquid

  Features:
  - Desktop: vertical thumbnail rail beside main viewport
  - RTL: thumbnail rail flips to inline-end side automatically (CSS logical)
  - Slide track driven by Custom Element (mallem-product-gallery)
  - Image 0: eager + fetchpriority=high for LCP
  - All others: loading=lazy
  - Explicit width/height on every image (prevents CLS)
  - Optional zoom on hover (pointer: fine devices only)
  - Mobile: thumbnails hidden, dot indicator row shown
  - ARIA live region announces current slide to screen readers

  RTL: CSS logical properties throughout. JS reads isRTL from
       window.Mallem.isRTL and inverts translateX sign.
  Performance: Lazy images, CSS contain, rAF for DOM mutations.
{%- endcomment -%}

{%- liquid
  assign media_count = product.media | size
  assign thumb_position = section.settings.gallery_thumbnails_position | default: 'left'
  assign enable_zoom    = section.settings.enable_zoom
  assign image_ratio    = section.settings.image_ratio | default: 'portrait'
-%}

<mallem-product-gallery
  class="mallem-gallery mallem-gallery--thumbs-{{ thumb_position }} mallem-gallery--{{ image_ratio }}"
  data-mallem-gallery
  role="region"
  aria-label="{{ 'mallem.product.gallery_label' | t }}"
  aria-roledescription="carousel"
>

  {%- comment -%} ── Thumbnail rail (hidden on mobile via CSS) ─────────────── {%- endcomment -%}
  {%- if thumb_position != 'hidden' and media_count > 1 -%}
    <div
      class="mallem-gallery__thumbs mallem-gallery__thumbs--{{ thumb_position }}"
      role="tablist"
      aria-label="{{ 'mallem.product.gallery_label' | t }}"
    >
      {%- for media in product.media -%}
        <button
          class="mallem-gallery__thumb{% if forloop.first %} mallem-gallery__thumb--active{% endif %}"
          data-mallem-thumb
          data-mallem-index="{{ forloop.index0 }}"
          role="tab"
          aria-selected="{{ forloop.first | json }}"
          aria-label="{{ 'mallem.product.gallery_go_to' | t: index: forloop.index }}"
          aria-controls="mallem-slide-{{ section.id }}-{{ forloop.index0 }}"
          type="button"
        >
          {%- if media.media_type == 'image' or media.preview_image -%}
            {%- assign thumb_src = media.preview_image -%}
            <img
              src="{{ thumb_src | image_url: width: 120 }}"
              alt="{{ media.alt | escape | default: product.title | escape }}"
              width="120"
              height="120"
              loading="lazy"
              class="mallem-gallery__thumb-img"
            >
          {%- endif -%}
        </button>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%} ── Main viewport ─────────────────────────────────────────── {%- endcomment -%}
  <div class="mallem-gallery__viewport" aria-live="polite" aria-atomic="false">

    {%- comment -%} Slide track — JS transforms this to slide between images {%- endcomment -%}
    <div
      class="mallem-gallery__track"
      data-mallem-gallery-track
      role="presentation"
    >
      {%- for media in product.media -%}
        {%- assign is_first = forloop.first -%}
        <div
          class="mallem-gallery__slide{% if enable_zoom and media.media_type == 'image' %} mallem-gallery__slide--zoomable{% endif %}"
          data-mallem-slide
          data-mallem-index="{{ forloop.index0 }}"
          id="mallem-slide-{{ section.id }}-{{ forloop.index0 }}"
          role="tabpanel"
          aria-label="{{ 'mallem.product.gallery_go_to' | t: index: forloop.index }}"
          aria-roledescription="slide"
        >

          {%- if media.media_type == 'image' -%}
            {%- liquid
              assign img_width  = media.width  | default: 1200
              assign img_height = media.height | default: 1200
              if img_width > 1200
                assign img_width  = 1200
                assign img_height = media.height | times: 1200 | divided_by: media.width
              endif
            -%}
            <img
              src="{{ media | image_url: width: 1200 }}"
              srcset="
                {{ media | image_url: width: 600  }} 600w,
                {{ media | image_url: width: 900  }} 900w,
                {{ media | image_url: width: 1200 }} 1200w
              "
              sizes="(min-width: 990px) 55vw, 100vw"
              alt="{{ media.alt | escape | default: product.title | escape }}"
              width="{{ img_width }}"
              height="{{ img_height }}"
              {% if is_first %}
                loading="eager"
                fetchpriority="high"
              {% else %}
                loading="lazy"
              {% endif %}
              class="mallem-gallery__img"
            >

          {%- elsif media.media_type == 'video' -%}
            <div class="mallem-gallery__video-wrapper">
              {{ media | video_tag: class: 'mallem-gallery__video', autoplay: false, controls: true, muted: false, loop: false }}
            </div>

          {%- elsif media.media_type == 'external_video' -%}
            <div class="mallem-gallery__video-wrapper">
              {{ media | external_video_tag: class: 'mallem-gallery__video' }}
            </div>

          {%- elsif media.media_type == 'model' -%}
            <div class="mallem-gallery__model-wrapper">
              {{ media | model_viewer_tag: class: 'mallem-gallery__model', reveal: 'interaction', data-shopify-feature: '1.0' }}
            </div>

          {%- else -%}
            {%- comment -%} Fallback for unsupported media types {%- endcomment -%}
            <img
              src="{{ media.preview_image | image_url: width: 1200 }}"
              alt="{{ media.alt | escape | default: product.title | escape }}"
              width="1200"
              height="1200"
              loading="lazy"
              class="mallem-gallery__img"
            >
          {%- endif -%}

        </div><!-- /.mallem-gallery__slide -->
      {%- else -%}
        {%- comment -%} No media — show featured image fallback {%- endcomment -%}
        <div class="mallem-gallery__slide" data-mallem-slide data-mallem-index="0">
          {{ product | image_url: width: 1200 | image_tag:
            class: 'mallem-gallery__img',
            loading: 'eager',
            fetchpriority: 'high',
            width: 1200,
            height: 1200
          }}
        </div>
      {%- endfor -%}
    </div><!-- /.mallem-gallery__track -->

    {%- comment -%} Previous / Next buttons (visible on desktop) {%- endcomment -%}
    {%- if media_count > 1 -%}
      <button
        class="mallem-gallery__arrow mallem-gallery__arrow--prev"
        data-mallem-gallery-prev
        aria-label="{{ 'mallem.product.gallery_previous' | t }}"
        type="button"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
          <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button
        class="mallem-gallery__arrow mallem-gallery__arrow--next"
        data-mallem-gallery-next
        aria-label="{{ 'mallem.product.gallery_next' | t }}"
        type="button"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true" focusable="false">
          <path d="M6 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    {%- endif -%}

    {%- comment -%} Accessible live announcement (screen readers) {%- endcomment -%}
    <span
      class="mallem-sr-only"
      data-mallem-gallery-announce
      aria-live="assertive"
      aria-atomic="true"
    ></span>

  </div><!-- /.mallem-gallery__viewport -->

  {%- comment -%} ── Mobile dot indicators ─────────────────────────────────── {%- endcomment -%}
  {%- if media_count > 1 -%}
    <div
      class="mallem-gallery__dots"
      data-mallem-gallery-dots
      role="tablist"
      aria-label="{{ 'mallem.product.gallery_label' | t }}"
    >
      {%- for media in product.media -%}
        <button
          class="mallem-gallery__dot{% if forloop.first %} mallem-gallery__dot--active{% endif %}"
          data-mallem-dot
          data-mallem-index="{{ forloop.index0 }}"
          role="tab"
          aria-selected="{{ forloop.first | json }}"
          aria-label="{{ 'mallem.product.gallery_go_to' | t: index: forloop.index }}"
          aria-controls="mallem-slide-{{ section.id }}-{{ forloop.index0 }}"
          type="button"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}

</mallem-product-gallery>
